# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local sqlite databases
*.db
*.db-journal

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit .env.example only
.env
.env.*
!.env.example

# vercel
.vercel

# typescript / tooling
*.tsbuildinfo
next-env.d.ts
.turbo

# prisma client (generated on npm install)
/src/generated/prisma

# cursor / editor local state
.cursor/
.idea/
.vscode/

# runtime user uploads (demo sample COA is whitelisted)
/public/uploads/*
!/public/uploads/.gitkeep
!/public/uploads/sample-coa.pdf

# deploy secrets (examples are committed)
deploy/**/stack.env
