generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ProductCategory {
  GLP1_METABOLIC
  GROWTH_SECRETAGOGUE
  HEALING_REPAIR
  MITOCHONDRIAL
  NEUROPEPTIDE
  LONGEVITY
  MELANOCORTIN
  SUPPLIES
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentMethod {
  PAYPAL
  CRYPTO
  MANUAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  FREE_SHIPPING
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model StoreSettings {
  id                   String   @id @default("default")
  siteName             String   @default("Peptides")
  legalEntity          String   @default("Peptides Cafe")
  siteUrl              String   @default("https://peptides.cafe")
  researchDisclaimer   String   @default("For laboratory and research use only. Not for human or veterinary consumption. Buyer assumes full responsibility for compliance with local laws.")
  defaultLegalNotice   String   @default("This product is sold strictly for in-vitro research purposes. It is not a drug, food, or cosmetic.")
  blockedCountries     String   @default("US,CA,AU")
  paypalEnabled        Boolean  @default(false)
  paypalClientId       String   @default("")
  paypalClientSecret   String   @default("")
  paypalMode           String   @default("sandbox")
  cryptoEnabled        Boolean  @default(false)
  manualPaymentEnabled Boolean  @default(true)
  manualPaymentInstructions String @default("We will email wire/ACH details after you place your order. Reference your order ID on payment.")
  nowpaymentsApiKey    String   @default("")
  nowpaymentsIpnSecret String   @default("")
  resendApiKey         String   @default("")
  edgeProtectionEnabled Boolean @default(false)
  edgeProvider         String   @default("crowdsec")
  edgeApiKey           String   @default("")
  emailFrom            String   @default("orders@peptides.cafe")
  updatedAt            DateTime @updatedAt
}

model Product {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  category     ProductCategory
  description  String
  priceCents   Int
  stock        Int             @default(0)
  purity       String?
  casNumber    String?
  sku          String          @unique
  images       Json         @default("[]")
  isActive     Boolean         @default(true)
  legalNotice  String?
  groupKey     String?
  variantLabel String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  coaDocuments CoaDocument[]
  orderItems   OrderItem[]
  reviews      Review[]

  @@index([groupKey])
}

model Review {
  id         String       @id @default(cuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  authorEmail String?
  rating     Int
  title      String?
  body       String
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([productId, status])
}

model CoaDocument {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchCode String
  fileUrl   String
  issuedAt  DateTime
  labName   String?
  createdAt DateTime @default(now())
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  isActive   Boolean    @default(true)
  maxUses    Int?
  usedCount  Int        @default(0)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  email           String
  shippingAddress Json
  status          OrderStatus   @default(AWAITING_PAYMENT)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  subtotalCents   Int           @default(0)
  shippingCents   Int           @default(0)
  discountCents   Int           @default(0)
  couponCode      String?
  totalCents      Int
  cryptoInvoiceId   String?
  cryptoPaymentUrl  String?
  cryptoCurrency    String?
  paypalOrderId   String?
  paypalCaptureId String?
  paypalCapturedAt DateTime?
  accessToken     String        @unique @default(cuid())
  trackingNumber  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventHash String
  createdAt DateTime @default(now())

  @@unique([provider, eventHash])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  qty            Int
  unitPriceCents Int
}
