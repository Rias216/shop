# Required
DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-a-long-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Branding (applied when you run db:seed)
# NEXT_PUBLIC_SITE_NAME="Research Supply Store"
# NEXT_PUBLIC_LEGAL_ENTITY="Your Legal Entity"
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Optional — first-run admin seed only (change before production)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-in-production"

# Optional — encrypt PayPal/API keys in StoreSettings (production recommended)
# SETTINGS_ENCRYPTION_KEY="generate-another-long-random-secret"

# Optional — imported on first seed if set (else configure in Admin → Settings)
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_MODE="sandbox"
# NOWPAYMENTS_API_KEY=""
# NOWPAYMENTS_IPN_SECRET=""
# RESEND_API_KEY=""
# EMAIL_FROM="orders@your-domain.com"
# BLOCKED_COUNTRIES="US,CA"

# Optional perf profiling flags (dev/staging)
# PERF_LOG="1"
# NEXT_PUBLIC_PERF_LOG="1"
